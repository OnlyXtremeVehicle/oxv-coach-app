# ============================================================
# OXV Coach — Variables d'environnement
# ============================================================
#
# IMPORTANT :
# 1. Copiez ce fichier en `.env` à la racine du projet
# 2. Remplissez les valeurs réelles dans `.env`
# 3. NE JAMAIS commiter le fichier `.env` (il est dans .gitignore)
# 4. Le fichier `.env.example` peut être commité (pas de secrets)
#
# Pour obtenir vos credentials Supabase :
# Voir docs/architecture/04_SUPABASE_CONNECTION_GUIDE.md
#
# ============================================================


# ----------------------------------------------------------------
# SUPABASE — Connexion à la base existante OXV
# ----------------------------------------------------------------

# URL du projet Supabase (visible dans Project Settings → API)
# Format : https://[project-id].supabase.co
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon key (clé publique, utilisable côté app mobile)
# Visible dans Project Settings → API → Project API keys → anon public
# Peut être commitée dans le code de l'app (Supabase RLS protège les données)
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service role key (clé admin, NE JAMAIS exposer côté client)
# Visible dans Project Settings → API → Project API keys → service_role
# À utiliser UNIQUEMENT côté serveur (Edge Functions, scripts admin)
# Pour le développement local, ne PAS mettre cette clé dans l'app mobile
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------------
# EXPO — Configuration de l'app React Native
# ----------------------------------------------------------------

# Identifiant unique de l'app (bundle ID iOS / package Android)
# Format reverse-domain
EXPO_PUBLIC_BUNDLE_ID=fr.oxvehicle.coach

# Version de l'app affichée à l'utilisateur
EXPO_PUBLIC_APP_VERSION=1.0.0

# Build number (à incrémenter à chaque soumission App Store)
EXPO_PUBLIC_BUILD_NUMBER=1

# Mesure d'audience RGPD (§9). Domaine Plausible. Laisser VIDE pour
# désactiver totalement la mesure d'audience (rien n'est envoyé).
# Ex : oxvehicle.fr (le site doit être ajouté dans le compte Plausible)
EXPO_PUBLIC_PLAUSIBLE_DOMAIN=

# Variables publiques exposées au client (préfixe EXPO_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry (remontée d'erreurs, preview/production uniquement). Laisser VIDE
# pour désactiver (initSentry reste no-op). Lu par src/lib/sentry.ts.
# Le plugin config Sentry a été retiré d'app.json en sem 14 (conflit Gradle) :
# le module natif reste via autolinking, seul le DSN est requis pour activer.
EXPO_PUBLIC_SENTRY_DSN=


# ----------------------------------------------------------------
# GOOGLE MAPS — Clé Android (carte sociale §7.2 + écosystème §8)
# ----------------------------------------------------------------
# iOS utilise Apple Maps (PROVIDER_DEFAULT) -> AUCUNE clé nécessaire.
# Android REQUIERT une clé "Maps SDK for Android", restreinte a l'app :
#   - Application restriction : Android apps
#   - Package name            : fr.oxvehicle.app
#   - SHA-1                    : empreinte du keystore EAS (eas credentials)
#   - API restriction         : "Maps SDK for Android" uniquement
# La clé n'est JAMAIS commitée. Injectée au build via app.config.js.
#   - build EAS : eas secret:create --scope project \
#                   --name GOOGLE_MAPS_ANDROID_KEY --value <clé> --type string
#   - local     : la définir ici dans .env (gitignored)
GOOGLE_MAPS_ANDROID_KEY=


# ----------------------------------------------------------------
# RACEBOX — Configuration du boîtier de télémétrie
# ----------------------------------------------------------------

# UUID du service BLE RaceBox Mini (standard, ne pas modifier)
RACEBOX_SERVICE_UUID=6E400001-B5A3-F393-E0A9-E50E24DCCA9E

# UUID des caractéristiques (rx, tx, ne pas modifier)
RACEBOX_RX_CHARACTERISTIC=6E400002-B5A3-F393-E0A9-E50E24DCCA9E
RACEBOX_TX_CHARACTERISTIC=6E400003-B5A3-F393-E0A9-E50E24DCCA9E


# ----------------------------------------------------------------
# FLIC 2 — Bouton BLE de marquage manuel
# ----------------------------------------------------------------

# Service UUID Flic 2 (standard)
FLIC_SERVICE_UUID=00001523-1212-EFDE-1523-785FEABCD123


# ----------------------------------------------------------------
# OPENAI — Génération du Debrief J+1 (côté serveur uniquement)
# ----------------------------------------------------------------

# Clé API OpenAI (utilisée par l'Edge Function `generate_debrief`)
# NE PAS exposer côté client
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle utilisé pour la génération
OPENAI_MODEL=gpt-4o


# ----------------------------------------------------------------
# ELEVENLABS — Synthèse vocale du rituel J-2 (côté serveur)
# ----------------------------------------------------------------

# Clé API ElevenLabs
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la voix utilisée pour OXV (à choisir dans la voice library)
ELEVENLABS_VOICE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------------
# RESEND — Envoi des emails transactionnels (côté serveur)
# ----------------------------------------------------------------

# Clé API Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse d'envoi par défaut
RESEND_FROM_EMAIL=noreply@oxvehicle.fr
RESEND_FROM_NAME=OXV Coach


# ----------------------------------------------------------------
# ENVIRONNEMENT
# ----------------------------------------------------------------

# Environnement actuel
# Valeurs possibles : development, preview, production
NODE_ENV=development

# Active les logs verbeux en développement
DEBUG=false

# URL de l'API OXV pour le site web (pour deep links)
OXV_WEB_URL=https://oxvehicle.fr


# ============================================================
# FIN DU FICHIER .env.example
# ============================================================
#
# Récapitulatif des actions nécessaires :
#
# [ ] 1. Créer le projet Supabase (déjà fait pour OXV)
# [ ] 2. Copier ce fichier en `.env`
# [ ] 3. Remplir SUPABASE_URL et SUPABASE_ANON_KEY (publiques)
# [ ] 4. Pour le développement, c'est suffisant
# [ ] 5. Pour les Edge Functions, remplir les clés serveur
#
# ============================================================
