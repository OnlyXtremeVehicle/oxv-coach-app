# OXV Coach — .gitattributes
# Normalise les line endings et gère les fichiers binaires correctement
# ============================================================

# DÉFAUT : forcer LF pour tous les fichiers texte
# ============================================================
* text=auto eol=lf

# ============================================================
# FICHIERS SOURCE — toujours LF
# ============================================================
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# ============================================================
# CONFIGURATION — toujours LF
# ============================================================
*.config.js    text eol=lf
.env.example   text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf

# ============================================================
# SCRIPTS SHELL — impérativement LF
# (sinon "bad interpreter" en CI Linux)
# ============================================================
*.sh        text eol=lf
*.bash      text eol=lf

# ============================================================
# FICHIERS WINDOWS-SPÉCIFIQUES — autorisés en CRLF
# ============================================================
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# ============================================================
# BINAIRES — pas de transformation
# ============================================================
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.ubx       binary
*.mp3       binary
*.mp4       binary
*.wav       binary

# ============================================================
# FICHIERS GÉNÉRÉS — exclus des stats GitHub & du diff bruyant
# ============================================================
package-lock.json -diff linguist-generated
yarn.lock         -diff linguist-generated
*.lockb           binary linguist-generated
src/types/database.types.ts linguist-generated
